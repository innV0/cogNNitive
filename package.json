{
  "name": "@innv0/cognnitive",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm --prefix packages/innfo-core run build && npm --prefix apps/innfo-editor run typecheck",
    "test": "npm --prefix packages/innfo-core test && npm --prefix apps/innfo-editor test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.62.1",
    "vue-eslint-parser": "^9.4.3"
  }
}

{
  "name": "@innv0/innfo-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm --prefix ../../packages/innfo-core run build",
    "dev": "vite",
    "prebuild": "npm --prefix ../../packages/innfo-core run build",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "pretest": "npm --prefix ../../packages/innfo-core run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@innv0/innfo-core": "*",
    "@tanstack/vue-virtual": "^3.13.31",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "dagre": "^0.8.5",
    "dompurify": "^3.2.0",
    "lucide-vue-next": "^0.395.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "pinia": "^2.1.0",
    "radix-vue": "^1.8.5",
    "tailwind-merge": "^2.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/d3": "^7.4.3",
    "@types/d3-sankey": "^0.12.5",
    "@types/dompurify": "^3.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.19",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^14.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.0"
  }
}
